# Travclan auth
TRAVCLAN_BEARER_TOKEN=

# API hosts
TRAVCLAN_STATIC_CONTENT_BASE_URL=https://hotels-v1.travclan.com
TRAVCLAN_REVIEWS_BASE_URL=https://hotel-api-v3-qa.travclan.com

# Reviews API headers
TRAVCLAN_INTERNAL_API_TOKEN=
TRAVCLAN_MEMBER_CODE=

# Output
OUTPUT_ENABLED=true
OUTPUT_DIR=output

# Vector preparation
HOTEL_CHUNK_SIZE=1500
HOTEL_CHUNK_OVERLAP=200
HOTEL_MAX_IMAGE_URLS=10
SKIP_UNCHANGED_VECTORS=true

# Embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=512

# Pinecone
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_HOTEL_NAMESPACE=hotel-static-content
PINECONE_UPSERT_BATCH_SIZE=100

# Future: PostgreSQL persistence (not implemented yet)
# POSTGRES_ENABLED=false
# POSTGRES_DSN=
